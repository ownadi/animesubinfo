<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.subtitles.animesubinfo"
       name="AnimeSub.info"
       version="0.2.0"
       provider-name="ownadi">
  <requires>
    <import addon="xbmc.python" version="3.0.0" />
  </requires>
  <extension point="xbmc.subtitle.module" library="default.py" />
  <extension point="xbmc.addon.metadata">
    <summary lang="en_GB">Polish anime subtitles from AnimeSub.info</summary>
    <description lang="en_GB">Lists ranked Polish subtitle matches for the currently playing anime and downloads the selected result from AnimeSub.info.</description>
    <platform>all</platform>
    <language>pl</language>
    <license>MIT</license>
    <source>https://github.com/ownadi/animesubinfo</source>
  </extension>
</addon>
